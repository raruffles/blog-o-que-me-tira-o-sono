---
import { posts } from '../../data/posts.js';

export function getStaticPaths() {
  return Object.entries(posts).map(([slug, post]) => ({
    params: { slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---
<html lang="pt-BR" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.title} | O que me tira o sono</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Dosis:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="O que me tira o sono | P.H">
        <span class="brand-mark">O que me tira o sono</span>
        <span class="brand-divider" aria-hidden="true"></span>
        <span class="brand-signature">P.H</span>
      </a>

      <div class="header-actions">
        <button class="theme-toggle" type="button" aria-pressed="false" aria-label="Alternar para modo escuro" data-theme-toggle>
          <span class="theme-toggle-track" aria-hidden="true">
            <span class="theme-toggle-thumb"></span>
          </span>
          <span class="theme-toggle-label">Normal</span>
        </button>

        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
          <span></span>
          <span></span>
          <span></span>
          <span class="sr-only">Abrir menu</span>
        </button>
      </div>

      <nav class="site-nav" id="site-menu" data-menu>
        <a href="/">Home</a>
        <a href="/#about">Sobre o blog</a>
        <a href="/#contact">Contato</a>
      </nav>
    </header>

    <main class="post-page">
      <section class="post-hero">
        <div class="post-intro">
          <span class="post-kicker">Crônica</span>
          <h1>{post.title}</h1>
          <p class="reading-time">{post.readTime}</p>
        </div>

        <div class={`post-visual ${post.color}`} aria-hidden="true"></div>
      </section>

      <article class="post-body">
        {post.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </article>
    </main>

    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.querySelector('[data-theme-toggle]');
      const menuToggle = document.querySelector('[data-menu-toggle]');
      const menu = document.querySelector('[data-menu]');

      const applyTheme = (theme) => {
        root.dataset.theme = theme;
        const isDark = theme === 'dark';
        themeToggle.setAttribute('aria-pressed', String(isDark));
        themeToggle.setAttribute('aria-label', isDark ? 'Alternar para modo normal' : 'Alternar para modo escuro');
        themeToggle.querySelector('.theme-toggle-label').textContent = isDark ? 'Dark' : 'Normal';
      };

      const savedTheme = localStorage.getItem('blog-theme');
      const initialTheme = savedTheme === 'dark' || savedTheme === 'light'
        ? savedTheme
        : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

      applyTheme(initialTheme);

      themeToggle.addEventListener('click', () => {
        const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('blog-theme', nextTheme);
        applyTheme(nextTheme);
      });

      menuToggle.addEventListener('click', () => {
        const isOpen = menu.classList.toggle('open');
        menuToggle.setAttribute('aria-expanded', String(isOpen));
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
        });
      });
    </script>

    <style>
      :root {
        --bg: #ffffff;
        --panel: #f7f7f6;
        --text: #121212;
        --muted: #5f6268;
        --line: rgba(18, 18, 18, 0.12);
        --accent: #121212;
        --accent-soft: rgba(18, 18, 18, 0.06);
        --shadow: 0 18px 48px rgba(0, 0, 0, 0.08);
      }

      html[data-theme='dark'] {
        --bg: #0c0d10;
        --panel: #16191f;
        --text: #f4f3ef;
        --muted: #b3b6bd;
        --line: rgba(255, 255, 255, 0.14);
        --accent: #f4f3ef;
        --accent-soft: rgba(255, 255, 255, 0.08);
        --shadow: 0 20px 54px rgba(0, 0, 0, 0.28);
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Montserrat', sans-serif;
        font-weight: 300;
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 20px;
        padding: 22px clamp(22px, 3.5vw, 42px);
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(16px);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
      }

      .brand-mark,
      .brand-signature,
      .post-kicker,
      .section-label,
      .site-nav a {
        font-family: 'Montserrat', sans-serif;
        font-weight: 300;
        letter-spacing: 0.06em;
      }

      .brand-mark {
        font-size: 1.95rem;
        line-height: 1.5;
        text-transform: uppercase;
      }

      .brand-divider {
        width: 1px;
        height: 54px;
        background: var(--line);
      }

      .brand-signature {
        font-size: 1.95rem;
        line-height: 1.5;
        text-transform: uppercase;
      }

      .header-actions {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        gap: 12px;
      }

      .theme-toggle,
      .menu-toggle {
        appearance: none;
        border: 0;
        background: transparent;
        color: var(--text);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 0;
        cursor: pointer;
      }

      .theme-toggle {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 10px 6px 6px;
        background: var(--panel);
      }

      .theme-toggle-label {
        font-size: 0.84rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .theme-toggle-track {
        position: relative;
        width: 46px;
        height: 26px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: var(--accent-soft);
        padding: 2px;
      }

      .theme-toggle-thumb {
        display: block;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--accent);
        transform: translateX(0);
        transition: transform 0.25s ease;
      }

      html[data-theme='dark'] .theme-toggle-thumb {
        transform: translateX(20px);
      }

      .menu-toggle {
        width: 48px;
        height: 48px;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
      }

      .menu-toggle span:not(.sr-only) {
        width: 28px;
        height: 2px;
        background: var(--text);
        display: block;
      }

      .site-nav {
        grid-column: 1 / -1;
        display: none;
        flex-direction: column;
        gap: 0;
        margin-top: 8px;
      }

      .site-nav.open { display: flex; }

      .site-nav a {
        padding: 14px 0;
        border-top: 1px solid var(--line);
        font-size: 0.98rem;
        text-transform: uppercase;
      }

      .post-page {
        padding: clamp(24px, 4vw, 48px);
      }

      .post-hero {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        gap: 28px;
      }

      .post-intro {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        min-height: 320px;
        padding: 32px 12px;
      }

      .post-kicker {
        font-size: 0.82rem;
        color: var(--muted);
        text-transform: uppercase;
      }

      .post-intro h1 {
        margin: 18px 0 0;
        font-family: 'Dosis', sans-serif;
        font-size: clamp(2rem, 3.4vw, 2.25rem);
        font-weight: 300;
        line-height: 1.05;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        max-width: 36ch;
      }

      .reading-time {
        margin: 18px 0 0;
        font-size: 0.92rem;
        color: var(--muted);
      }

      .post-visual {
        min-height: 420px;
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }

      .tone-forest {
        background:
          radial-gradient(circle at 30% 25%, rgba(197, 255, 125, 0.32), transparent 26%),
          linear-gradient(155deg, #2f4f2d, #6e8d2f 34%, #201f15 70%, #3d281a 100%);
      }

      .tone-sky {
        background:
          radial-gradient(circle at 60% 22%, rgba(255, 255, 255, 0.58), transparent 18%),
          linear-gradient(160deg, #162437, #4e7097 40%, #d7b56b 100%);
      }

      .tone-paper {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.3)),
          linear-gradient(160deg, #f4eee8, #e7e0da);
      }

      .tone-amber {
        background:
          radial-gradient(circle at 70% 30%, rgba(255, 211, 132, 0.24), transparent 26%),
          linear-gradient(155deg, #1a1411, #6b341c 42%, #d39a58 100%);
      }

      .post-body {
        max-width: 760px;
        margin: clamp(40px, 8vw, 72px) auto 0;
        text-align: center;
      }

      .post-body p {
        margin: 0;
        font-size: 1.125rem;
        line-height: 1.5;
        color: var(--muted);
      }

      .post-body p + p {
        margin-top: 28px;
      }

      @media (min-width: 900px) {
        .post-hero {
          grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.15fr);
          align-items: center;
        }

        .post-intro {
          min-height: 520px;
        }

        .site-nav {
          position: absolute;
          right: clamp(22px, 3.5vw, 42px);
          top: calc(100% + 1px);
          min-width: 260px;
          padding: 12px 0;
          border: 1px solid var(--line);
          background: var(--bg);
          box-shadow: var(--shadow);
        }

        .site-nav a {
          padding: 14px 18px;
          border-top: 0;
          border-bottom: 1px solid var(--line);
        }

        .site-nav a:last-child { border-bottom: 0; }
      }

      @media (max-width: 899px) {
        .site-header {
          grid-template-columns: auto 1fr auto;
        }

        .brand {
          gap: 12px;
        }

        .brand-mark,
        .brand-signature {
          font-size: 1.1rem;
          line-height: 1.5;
        }

        .brand-divider {
          height: 42px;
        }

        .theme-toggle-label {
          display: none;
        }

        .post-visual {
          min-height: 320px;
        }
      }
    </style>
  </body>
</html>