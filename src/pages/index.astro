---
import logo from '../logo.png';
import PostGrid from '../components/blog/PostGrid.jsx';
import { keystaticReader } from '../lib/keystatic.ts';

const posts = (await keystaticReader.collections.posts.all()).map(({ slug, entry }) => ({
  slug,
  ...entry,
}));
---
<html lang="pt-BR" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="O que me tira o sono" />
    <title>O que me tira o sono | P.H</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Dosis:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#home" aria-label="O que me tira o sono | P.H">
        <img src={logo.src} alt="O que me tira o sono | P.H" />
      </a>

      <div class="header-actions">
        <button class="theme-toggle" type="button" aria-pressed="false" aria-label="Alternar tema" data-theme-toggle>
          <span class="theme-toggle-label">Normal</span>
        </button>

        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
          <span></span>
          <span></span>
          <span></span>
          <span class="sr-only">Abrir menu</span>
        </button>
      </div>

      <nav class="site-nav" id="site-menu" data-menu>
        <a href="#home">Home</a>
        <a href="#about">Sobre o blog</a>
        <a href="#contact">Contato</a>
      </nav>
    </header>

    <main class="page-shell" id="home">
      <section class="home-layout">
        <PostGrid posts={posts} />
      </section>
    </main>

    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.querySelector('[data-theme-toggle]');
      const menuToggle = document.querySelector('[data-menu-toggle]');
      const menu = document.querySelector('[data-menu]');

      const applyTheme = (theme) => {
        root.dataset.theme = theme;
        const isDark = theme === 'dark';
        themeToggle.setAttribute('aria-pressed', String(isDark));
        themeToggle.querySelector('.theme-toggle-label').textContent = isDark ? 'Dark' : 'Normal';
      };

      const savedTheme = localStorage.getItem('blog-theme');
      const initialTheme = savedTheme === 'dark' || savedTheme === 'light'
        ? savedTheme
        : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

      applyTheme(initialTheme);

      themeToggle.addEventListener('click', () => {
        const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('blog-theme', nextTheme);
        applyTheme(nextTheme);
      });

      menuToggle.addEventListener('click', () => {
        const isOpen = menu.classList.toggle('open');
        menuToggle.setAttribute('aria-expanded', String(isOpen));
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
        });
      });
    </script>

    <style>
      :root {
        --bg: #ffffff;
        --panel: #f7f7f6;
        --text: #121212;
        --muted: #5f6268;
        --line: rgba(18, 18, 18, 0.12);
        --accent: #121212;
        --accent-soft: rgba(18, 18, 18, 0.06);
        --shadow: 0 18px 48px rgba(0, 0, 0, 0.08);
      }

      html[data-theme='dark'] {
        --bg: #0c0d10;
        --panel: #16191f;
        --text: #f4f3ef;
        --muted: #b3b6bd;
        --line: rgba(255, 255, 255, 0.14);
        --accent: #f4f3ef;
        --accent-soft: rgba(255, 255, 255, 0.08);
        --shadow: 0 20px 54px rgba(0, 0, 0, 0.28);
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Montserrat', sans-serif;
        font-size: 18px;
        font-weight: 300;
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      p,
      li {
        font-size: 18px;
      }

      img { display: block; max-width: 100%; }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 16px;
        height: 64px;
        padding: 8px clamp(18px, 3vw, 32px);
        background: var(--bg);
      }

      .brand { display: inline-flex; width: fit-content; }

      .brand img {
        height: 48px;
        width: auto;
      }

      .header-actions {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        gap: 12px;
      }

      .theme-toggle,
      .menu-toggle {
        appearance: none;
        border: 0;
        background: transparent;
        color: var(--text);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 0;
        cursor: pointer;
      }

      .theme-toggle-label {
        font-size: 18px;
        font-weight: 300;
      }

      .menu-toggle {
        width: 40px;
        height: 40px;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
      }

      .menu-toggle span:not(.sr-only) {
        width: 28px;
        height: 2px;
        background: var(--text);
        display: block;
      }

      .site-nav {
        grid-column: 1 / -1;
        display: none;
        flex-direction: column;
        gap: 0;
        margin-top: 8px;
        background: var(--bg);
      }

      .site-nav.open { display: flex; }

      .site-nav a {
        padding: 14px 0;
        font-size: 18px;
        font-weight: 300;
        color: #000000;
      }

      .site-nav a:hover {
        color: #6b7280;
      }

      .page-shell {
        padding: clamp(24px, 4vw, 48px);
      }

      .home-layout {
        max-width: 1180px;
        margin: 0 auto;
      }

      .post-grid {
        display: grid;
        gap: 22px;
        grid-template-columns: 1fr;
      }

      .featured-card {
        min-width: 0;
      }

      .card-link {
        display: block;
      }

      .post-visual {
        width: 100%;
        aspect-ratio: 4 / 5;
        border: 0;
        box-shadow: none;
      }

      .tone-forest {
        background:
          radial-gradient(circle at 30% 25%, rgba(197, 255, 125, 0.32), transparent 26%),
          linear-gradient(155deg, #2f4f2d, #6e8d2f 34%, #201f15 70%, #3d281a 100%);
      }

      .tone-sky {
        background:
          radial-gradient(circle at 60% 22%, rgba(255, 255, 255, 0.58), transparent 18%),
          linear-gradient(160deg, #162437, #4e7097 40%, #d7b56b 100%);
      }

      .tone-paper {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.3)),
          linear-gradient(160deg, #f4eee8, #e7e0da);
      }

      .tone-amber {
        background:
          radial-gradient(circle at 70% 30%, rgba(255, 211, 132, 0.24), transparent 26%),
          linear-gradient(155deg, #1a1411, #6b341c 42%, #d39a58 100%);
      }

      .card-copy {
        padding: 12px 2px 0;
      }

      .post-title {
        margin: 0;
        font-family: 'Dosis', sans-serif;
        font-weight: 300;
        letter-spacing: 0.03em;
        line-height: 1.05;
        font-size: clamp(2rem, 2.6vw, 2.25rem);
        text-transform: uppercase;
        max-width: 36ch;
      }

      .post-meta {
        margin: 12px 0 0;
        color: var(--muted);
      }

      .featured-card-large .post-title {
        font-size: clamp(2.25rem, 3vw, 2.5rem);
      }

      @media (min-width: 900px) {
        .post-grid {
          grid-template-columns: 1.2fr 1fr 260px;
          align-items: start;
        }

        .featured-card:nth-child(1) {
          grid-column: 1;
        }

        .featured-card:nth-child(2) {
          grid-column: 2;
        }

        .featured-card:nth-child(3) {
          grid-column: 1;
        }

        .featured-card:nth-child(4) {
          grid-column: 2;
        }

        .site-nav {
          position: absolute;
          right: clamp(18px, 3vw, 32px);
          top: calc(100% + 1px);
          min-width: 260px;
          padding: 12px 0;
        }

        .site-nav a {
          padding: 14px 18px;
        }
      }
    </style>
  </body>
</html>