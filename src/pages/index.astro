---
import logo from '../logo.png';
import PostGrid from '../components/blog/PostGrid.jsx';
import { keystaticReader } from '../lib/keystatic.ts';

const posts = (await keystaticReader.collections.blog.all())
  .map(({ slug, entry }) => ({
    slug,
    ...entry,
  }))
  .sort((left, right) => new Date(right.pubDate).getTime() - new Date(left.pubDate).getTime());
---
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="O que me tira o sono" />
    <title>O que me tira o sono | P.H</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Dosis:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#home" aria-label="O que me tira o sono | P.H">
        <img src={logo.src} alt="O que me tira o sono | P.H" />
      </a>

      <div class="header-actions">
        <label class="search-bar" aria-label="Buscar posts">
          <span class="search-icon" aria-hidden="true">⌕</span>
          <input class="search-input" type="search" placeholder="Buscar" data-search-input />
        </label>

        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
          <span></span>
          <span></span>
          <span></span>
          <span class="sr-only">Abrir menu</span>
        </button>
      </div>

      <nav class="site-nav" id="site-menu" data-menu>
        <a href="#home">Home</a>
        <a href="#about">Sobre o blog</a>
        <a href="#contact">Contato</a>
      </nav>
    </header>

    <main class="page-shell" id="home">
      <section class="home-layout">
        <PostGrid posts={posts} />
      </section>
    </main>

    <script is:inline>
      const menuToggle = document.querySelector('[data-menu-toggle]');
      const menu = document.querySelector('[data-menu]');
      const searchInput = document.querySelector('[data-search-input]');
      const cards = document.querySelectorAll('[data-post-card]');

      const normalize = (value) =>
        value
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '');

      const filterCards = () => {
        const query = normalize(searchInput.value.trim());

        cards.forEach((card) => {
          const haystack = normalize(card.getAttribute('data-search-text') || '');
          card.hidden = Boolean(query) && !haystack.includes(query);
        });
      };

      searchInput.addEventListener('input', filterCards);

      menuToggle.addEventListener('click', () => {
        const isOpen = menu.classList.toggle('open');
        menuToggle.setAttribute('aria-expanded', String(isOpen));
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
        });
      });
    </script>

    <style>
      :root {
        --bg: #ffffff;
        --text: #121212;
        --muted: #5f6268;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Montserrat', sans-serif;
        font-size: 18px;
        font-weight: 300;
        line-height: 1.5;
      }

      :global(a),
      :global(a:visited),
      :global(a:hover),
      :global(a:active) {
        color: #000000;
        text-decoration: none;
      }

      :global(a:hover) {
        opacity: 0.72;
      }

      p,
      li {
        font-size: 18px;
      }

      img { display: block; max-width: 100%; }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 16px;
        height: 64px;
        padding: 8px clamp(18px, 3vw, 36px);
        background: var(--bg);
      }

      .brand { display: inline-flex; width: fit-content; }

      .brand img {
        height: 48px;
        width: auto;
      }

      .header-actions {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        gap: 14px;
      }

      .search-bar {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-width: 180px;
        padding: 0 14px;
        height: 40px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.04);
        color: #000000;
      }

      .search-icon {
        font-size: 18px;
        line-height: 1;
        color: #000000;
      }

      .search-input {
        width: 100%;
        border: 0;
        outline: none;
        background: transparent;
        color: #000000;
        font: inherit;
        font-size: 18px;
        font-weight: 300;
      }

      .search-input::placeholder {
        color: rgba(0, 0, 0, 0.48);
      }

      .menu-toggle {
        appearance: none;
        border: 0;
        background: transparent;
        color: var(--text);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 0;
        cursor: pointer;
      }

      .menu-toggle {
        width: 40px;
        height: 40px;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
      }

      .menu-toggle span:not(.sr-only) {
        width: 28px;
        height: 2px;
        background: var(--text);
        display: block;
      }

      .site-nav {
        grid-column: 1 / -1;
        display: none;
        flex-direction: column;
        gap: 0;
        margin-top: 6px;
        background: var(--bg);
      }

      .site-nav.open { display: flex; }

      .site-nav a {
        padding: 14px 0;
        font-size: 18px;
        font-weight: 300;
        color: #000000;
      }

      .site-nav a:hover {
        color: #6b7280;
      }

      .page-shell {
        padding: clamp(24px, 4vw, 56px) clamp(18px, 3vw, 36px) 56px;
      }

      .home-layout {
        max-width: 1480px;
        margin: 0 auto;
      }

      :global(.post-grid) {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 32px;
      }

      :global(.featured-card) {
        min-width: 0;
      }

      :global(.card-link) {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      :global(.post-visual) {
        width: 100%;
        border: 0;
        box-shadow: none;
        position: relative;
        overflow: hidden;
        background: #f4f0ea;
      }

      :global(.post-visual img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      :global(.ratio-short) { aspect-ratio: 4 / 3; }
      :global(.ratio-tall) { aspect-ratio: 4 / 5; }
      :global(.ratio-wide) { aspect-ratio: 16 / 10; }
      :global(.ratio-hero) { aspect-ratio: 5 / 6; }

      :global(.card-copy) {
        padding: 0 2px 0;
      }

      :global(.card-date) {
        display: block;
        margin: 0 0 10px;
        color: var(--muted);
        font-size: 18px;
      }

      :global(.post-title) {
        margin: 0;
        font-family: 'Montserrat', sans-serif;
        font-weight: 300;
        letter-spacing: -0.02em;
        line-height: 1.15;
        font-size: clamp(1.7rem, 2vw, 2.25rem);
        max-width: 18ch;
      }

      :global(.post-description) {
        margin: 10px 0 0;
        color: var(--muted);
        max-width: 34ch;
      }

      :global(.featured-card-large .post-title) {
        font-size: clamp(2rem, 2.6vw, 2.8rem);
        max-width: 14ch;
      }

      :global(.featured-card-large .post-visual) {
        aspect-ratio: 5 / 6;
      }

      @media (min-width: 900px) {
        .site-nav {
          position: absolute;
          right: clamp(18px, 3vw, 32px);
          top: calc(100% + 1px);
          min-width: 240px;
          padding: 12px 0;
        }

        .site-nav a {
          padding: 14px 18px;
        }

        .search-bar {
          min-width: 240px;
        }
      }

      @media (max-width: 899px) {
        .header-actions {
          gap: 10px;
        }

        .search-bar {
          min-width: 0;
          width: 140px;
          padding-inline: 12px;
        }

        .search-input::placeholder {
          color: transparent;
        }

        :global(.post-grid) {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>